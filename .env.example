# Database
DB_USER=talexis_user
DB_PASSWORD=talexis_secret
DB_NAME=talexis
DATABASE_URL=postgresql://talexis_user:talexis_secret@localhost:5432/talexis

# Auth
SECRET_KEY=change-me-to-a-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Cloud LLM (OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
