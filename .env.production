# ===== TALEXIS PRODUCTION CONFIGURATION =====
# Copy this file to .env and fill in your values

# --- Database ---
DB_USER=talexis_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=talexis

# --- Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# --- Domain ---
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=["https://yourdomain.com"]
VITE_API_URL=https://yourdomain.com
APP_PORT=80

# --- AI / LLM (choose one) ---
# Option A: OpenAI only (recommended for production — no Ollama needed)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Option B: Ollama (uncomment ollama service in docker-compose.yml)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Dodo Payments ---
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_PAYMENTS_ENV=live_mode
DODO_WEBHOOK_SECRET=your-webhook-secret

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
